# HyMeKo runtime environment — example.
#
# Copy to `.env` and edit. `.env` is gitignored.
# Sourced by `scripts/dev/activate.sh`. Picked up by `uv run --env-file .env`.
#
# Not all knobs are listed — grep the codebase for HSIKAN_/HYMEKO_ to find more:
#   grep -rhoE '(HSIKAN|HYMEKO)_[A-Z_]+' signedkan_wip/src/ hymeko_py/ | sort -u
#
# IMPORTANT: any HSIKAN_* var that affects cycle/walk enumeration MUST be part
# of `_topk_fingerprint` (signedkan_wip/src/cycle_cache.py) or the cache will
# silently return stale results across configs. See memory
# `feedback_cycle_cache_fingerprint.md`.

# ---------------------------------------------------------------------------
# Enumeration cache + per-vertex top-K (the production config)
# ---------------------------------------------------------------------------
# Caches enumerated cycles/walks under ~/.cache/hymeko/cycles_v1/.
# Strongly recommended for Slashdot / Epinions; harmless on Bitcoin.
# HYMEKO_CYCLE_CACHE=1

# Per-vertex top-K cycle/walk pruning (vs. global enumeration).
# Mode: "" (off) | per_vertex | global
# HSIKAN_TOPK_MODE=per_vertex
# HSIKAN_TOPK_K=128

# Degree-adaptive m_v (Section: degree_adaptive_mv_smoke memory).
# m_v(v) = clamp(ceil(c · deg(v)), min, max).
# HSIKAN_TOPK_M_V_C=1.0
# HSIKAN_TOPK_M_V_MIN=8
# HSIKAN_TOPK_M_V_MAX=256

# Cycle scorer / pruner (Rust strategy).
# Scorer:  balance | unbalanced | weighted_sum | fraction_negative
# Pruner:  none | balance | davis | unbalanced
# HSIKAN_TOPK_SCORER=balance
# HSIKAN_TOPK_PRUNER=none

# ---------------------------------------------------------------------------
# Architecture knobs (mixed-arity / attention / gates)
# ---------------------------------------------------------------------------
# Mixed tuple types passed to MixedAritySignedKAN. Walks dominate alpha on
# Bitcoin (memory: project_bitcoin_optuna_best_10seed_2026_05_13.md).
# HSIKAN_MIXED_TUPLES=c2,c5,w2,w3,w4

# Per-edge Catmull-Rom Highway gate (Slashdot SOTA — memory: edge_cr_5seed).
# HSIKAN_PER_EDGE_GATE=1

# Attention path + sparse top-K (memory: sparse_attention_synth).
# HSIKAN_ATTENTION_M_E=1
# HSIKAN_SPARSE_ATTN_K=8

# ---------------------------------------------------------------------------
# Performance — Triton fast path (memory: triton_kernel_integration)
# ---------------------------------------------------------------------------
# Forward kernel: 38–60× speedup at SOTA shape. Forward parity ≤2e-7.
# HSIKAN_TRITON_KERNEL=1
# Backward kernel: 92.5–93% memory savings. Closed-form gradients.
# HSIKAN_TRITON_BACKWARD=1
# HSIKAN_TORCH_COMPILE=reduce-overhead

# ---------------------------------------------------------------------------
# Determinism (CLAUDE.md §3) — required when comparing across runs
# ---------------------------------------------------------------------------
# MKL_CBWR=COMPATIBLE
# CUBLAS_WORKSPACE_CONFIG=:4096:8
# OMP_NUM_THREADS=1
# MKL_NUM_THREADS=1

# ---------------------------------------------------------------------------
# Demo GUI (signedkan_wip/src/demo/gui.py)
# ---------------------------------------------------------------------------
# Bind 0.0.0.0 to expose on the LAN; 127.0.0.1 for localhost only.
# HYMEKO_DEMO_HOST=0.0.0.0
# HYMEKO_DEMO_PORT=7860

# ---------------------------------------------------------------------------
# DO NOT enable — known broken
# ---------------------------------------------------------------------------
# HSIKAN_STRICT_PROTOCOL=1
#   ↑ zeros M_e uniformly for every edge train+test, producing 0.5±0.0
#     filter artifacts. Real σ-masked-cycle-products fix is on the backlog.
#     Memory: project_strict_protocol_broken_2026_05_13.md
