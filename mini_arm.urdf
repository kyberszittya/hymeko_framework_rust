<?xml version="1.0" encoding="UTF-8"?>
<robot name="mini_arm">

  <link name="base_link">

    <inertial>
      <mass value="5"/>
    </inertial>


    <visual>

      <origin xyz="0 0 0.05" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>

  </link>

  <link name="spinner">

    <inertial>
      <mass value="1"/>
    </inertial>


    <visual>

      <origin xyz="0 0 0.1" rpy="0 0 0"/>

      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.1"/>
      </geometry>
    </collision>

  </link>







  <joint name="spin_joint" type="continuous">
    <parent link="base_link"/>
    <child link="spinner"/>
    <axis xyz="0 0 1"/>
  </joint>



</robot>
