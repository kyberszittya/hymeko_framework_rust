<?xml version="1.0"?>
<!--
  Gazebo model manifest for the dual_fanuc model directory.

  This manifest lets Gazebo discover the model by URI
  (`model://dual_fanuc`) once GZ_SIM_RESOURCE_PATH includes
  data/robotics/sim/.

  The model.sdf this points at is emitted from
  fanuc_lrmate200id.hymeko via the HymeKo compiler — see README.md.
-->
<model>
  <name>dual_fanuc</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>HyMeKo framework</name>
  </author>

  <description>
    FANUC LR Mate 200iD-style 6-DOF arm. Geometry from
    fanuc_lrmate200id.hymeko (single source of truth for both
    instances in the dual-arm world). For CAD-accurate FANUC
    meshes, swap in ROS-industrial fanuc_lrmate200id_support.
  </description>
</model>
