    @flow_block_07: lyr.dataflow { (+ z6, ~ block_7, - z7); }
    @flow_block_08: lyr.dataflow { (+ z7, ~ block_8, - z8); }
    @flow_block_09: lyr.dataflow { (+ z8, ~ block_9, - z9); }
    @flow_block_10: lyr.dataflow { (+ z9, ~ block_10, - z10); }
    @flow_block_11: lyr.dataflow { (+ z10, ~ block_11, - z11); }
    @flow_block_12: lyr.dataflow { (+ z11, ~ block_12, - z12); }
    @flow_block_13: lyr.dataflow { (+ z12, ~ block_13, - z13); }
    @flow_block_14: lyr.dataflow { (+ z13, ~ block_14, - z14); }
    @flow_block_15: lyr.dataflow { (+ z14, ~ block_15, - z15); }
    @flow_block_16: lyr.dataflow { (+ z15, ~ block_16, - z16); }
    @flow_block_17: lyr.dataflow { (+ z16, ~ block_17, - z17); }
    @flow_block_18: lyr.dataflow { (+ z17, ~ block_18, - z18); }
    @flow_block_19: lyr.dataflow { (+ z18, ~ block_19, - z19); }
    @flow_block_20: lyr.dataflow { (+ z19, ~ block_20, - z20); }
    @flow_block_21: lyr.dataflow { (+ z20, ~ block_21, - z21); }
    @flow_block_22: lyr.dataflow { (+ z21, ~ block_22, - z22); }
    @flow_block_23: lyr.dataflow { (+ z22, ~ block_23, - z23); }
    @flow_block_24: lyr.dataflow { (+ z23, ~ block_24, - z24); }
    @flow_block_25: lyr.dataflow { (+ z24, ~ block_25, - z25); }
    @flow_block_26: lyr.dataflow { (+ z25, ~ block_26, - z26); }
    @flow_block_27: lyr.dataflow { (+ z26, ~ block_27, - z27); }
    @flow_block_28: lyr.dataflow { (+ z27, ~ block_28, - z28); }
    @flow_block_29: lyr.dataflow { (+ z28, ~ block_29, - z29); }
    @flow_block_30: lyr.dataflow { (+ z29, ~ block_30, - z30); }
    @flow_block_31: lyr.dataflow { (+ z30, ~ block_31, - z31); }
    @flow_block_32: lyr.dataflow { (+ z31, ~ block_32, - z32); }
    @flow_block_33: lyr.dataflow { (+ z32, ~ block_33, - z33); }
    @flow_block_34: lyr.dataflow { (+ z33, ~ block_34, - z34); }
    @flow_block_35: lyr.dataflow { (+ z34, ~ block_35, - z35); }
    @flow_block_36: lyr.dataflow { (+ z35, ~ block_36, - z36); }
    @flow_block_37: lyr.dataflow { (+ z36, ~ block_37, - z37); }
    @flow_block_38: lyr.dataflow { (+ z37, ~ block_38, - z38); }
    @flow_block_39: lyr.dataflow { (+ z38, ~ block_39, - z39); }
    @flow_block_40: lyr.dataflow { (+ z39, ~ block_40, - z40); }
    @flow_head:    lyr.dataflow { (+ z40, ~ head,    - y);  }
}
