    z19: ten.t_activation { shape [16]; }
    z20: ten.t_activation { shape [16]; }
    z21: ten.t_activation { shape [16]; }
    z22: ten.t_activation { shape [16]; }
    z23: ten.t_activation { shape [16]; }
    z24: ten.t_activation { shape [16]; }
    z25: ten.t_activation { shape [16]; }
    z26: ten.t_activation { shape [16]; }
    z27: ten.t_activation { shape [16]; }
    z28: ten.t_activation { shape [16]; }
    z29: ten.t_activation { shape [16]; }
    z30: ten.t_activation { shape [16]; }
    z31: ten.t_activation { shape [16]; }
    z32: ten.t_activation { shape [16]; }
    z33: ten.t_activation { shape [16]; }
    z34: ten.t_activation { shape [16]; }
    z35: ten.t_activation { shape [16]; }
    z36: ten.t_activation { shape [16]; }
    z37: ten.t_activation { shape [16]; }
    z38: ten.t_activation { shape [16]; }
    z39: ten.t_activation { shape [16]; }
    z40: ten.t_activation { shape [16]; }
    y:  ten.t_output     { shape [10]; }

    proj: lyr.linear_layer { d_in 784; d_out 16; }

    block_1: lyr.residual_block { hidden 16; }
    block_2: lyr.residual_block { hidden 16; }
    block_3: lyr.residual_block { hidden 16; }
    block_4: lyr.residual_block { hidden 16; }
    block_5: lyr.residual_block { hidden 16; }
    block_6: lyr.residual_block { hidden 16; }
    block_7: lyr.residual_block { hidden 16; }
    block_8: lyr.residual_block { hidden 16; }
    block_9: lyr.residual_block { hidden 16; }
    block_10: lyr.residual_block { hidden 16; }
    block_11: lyr.residual_block { hidden 16; }
    block_12: lyr.residual_block { hidden 16; }
    block_13: lyr.residual_block { hidden 16; }
    block_14: lyr.residual_block { hidden 16; }
    block_15: lyr.residual_block { hidden 16; }
    block_16: lyr.residual_block { hidden 16; }
    block_17: lyr.residual_block { hidden 16; }
    block_18: lyr.residual_block { hidden 16; }
    block_19: lyr.residual_block { hidden 16; }
    block_20: lyr.residual_block { hidden 16; }
    block_21: lyr.residual_block { hidden 16; }
    block_22: lyr.residual_block { hidden 16; }
    block_23: lyr.residual_block { hidden 16; }
    block_24: lyr.residual_block { hidden 16; }
    block_25: lyr.residual_block { hidden 16; }
    block_26: lyr.residual_block { hidden 16; }
    block_27: lyr.residual_block { hidden 16; }
    block_28: lyr.residual_block { hidden 16; }
    block_29: lyr.residual_block { hidden 16; }
    block_30: lyr.residual_block { hidden 16; }
    block_31: lyr.residual_block { hidden 16; }
    block_32: lyr.residual_block { hidden 16; }
    block_33: lyr.residual_block { hidden 16; }
    block_34: lyr.residual_block { hidden 16; }
    block_35: lyr.residual_block { hidden 16; }
    block_36: lyr.residual_block { hidden 16; }
    block_37: lyr.residual_block { hidden 16; }
    block_38: lyr.residual_block { hidden 16; }
    block_39: lyr.residual_block { hidden 16; }
    block_40: lyr.residual_block { hidden 16; }

    head: lyr.linear_layer { d_in 16; d_out 10; }

    @flow_proj:    lyr.dataflow { (+ x,  ~ proj,    - z0); }
    @flow_block_01: lyr.dataflow { (+ z0, ~ block_1, - z1); }
    @flow_block_02: lyr.dataflow { (+ z1, ~ block_2, - z2); }
    @flow_block_03: lyr.dataflow { (+ z2, ~ block_3, - z3); }
