Minimal_Example
{
    // Meta value
    author "Csaba";
}
context
{
    // Simple integer
    val0 <int> 56;
    // String value
    val1 <string> "vakond";
    val2 <real> 56.891;
    /// Undefined value, get it in runtime
    val_undef <real>;
    val3 3444.4623;
    /// Redefine PI value
    pi 3.14156;
    // Untyped value
    val_float;
    // A simple vector
    vector [15.6, 17.8, 16.3, 12.3, 67.8, 45, 2];
}