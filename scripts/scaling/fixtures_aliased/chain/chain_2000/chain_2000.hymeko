        (+ l1997 [[0.000, 0.000, 0.100], [0.000, 0.000, 0.000]],
         - l1998,
         - ax.AXIS_Z);
    }
    @j1998: cj {
        (+ l1998 [[0.000, 0.000, 0.100], [0.000, 0.000, 0.000]],
         - l1999,
         - ax.AXIS_Z);
    }
}
