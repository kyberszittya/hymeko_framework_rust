<?xml version="1.0" encoding="UTF-8"?>
<robot name="moveo">
  <link name="world"/>

  <link name="base_link">
    <inertial>
      <mass value="25"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.025"/>
      <geometry>
        <cylinder radius="0.13" length="0.05"/>
      </geometry>
      <material name="color">
        <color rgba="1 0.776 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.025"/>
      <geometry>
        <cylinder radius="0.13" length="0.05"/>
      </geometry>
    </collision>
  </link>

  <link name="link_0">
    <inertial>
      <mass value="5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.1"/>
      <geometry>
        <cylinder radius="0.075" length="0.2"/>
      </geometry>
      <material name="color">
        <color rgba="1 0.776 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.1"/>
      <geometry>
        <cylinder radius="0.075" length="0.2"/>
      </geometry>
    </collision>
  </link>

  <link name="link_1">
    <inertial>
      <mass value="2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <cylinder radius="0.075" length="0.3"/>
      </geometry>
      <material name="color">
        <color rgba="0.98 0.824 0.6 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry>
        <cylinder radius="0.075" length="0.3"/>
      </geometry>
    </collision>
  </link>

  <link name="link_2">
    <inertial>
      <mass value="2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.125"/>
      <geometry>
        <cylinder radius="0.075" length="0.25"/>
      </geometry>
      <material name="color">
        <color rgba="1 0.776 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.125"/>
      <geometry>
        <cylinder radius="0.075" length="0.25"/>
      </geometry>
    </collision>
  </link>

  <link name="link_3">
    <inertial>
      <mass value="2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.16"/>
      <geometry>
        <cylinder radius="0.075" length="0.32"/>
      </geometry>
      <material name="color">
        <color rgba="1 0.776 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.16"/>
      <geometry>
        <cylinder radius="0.075" length="0.32"/>
      </geometry>
    </collision>
  </link>

  <link name="link_4">
    <inertial>
      <mass value="2"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.075"/>
      <geometry>
        <cylinder radius="0.075" length="0.15"/>
      </geometry>
      <material name="color">
        <color rgba="1 0.776 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.075"/>
      <geometry>
        <cylinder radius="0.075" length="0.15"/>
      </geometry>
    </collision>
  </link>

  <link name="tool">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.01" iyy="0.01" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.075 0.15 0.1"/>
      </geometry>
      <material name="color">
        <color rgba="1 0.776 0 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry>
        <box size="0.075 0.15 0.1"/>
      </geometry>
    </collision>
  </link>

  <joint name="j_fix" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0.0000 0.0000 0.0000"/>
  </joint>

  <joint name="j0" type="revolute">
    <parent link="base_link"/>
    <child link="link_0"/>
    <origin xyz="0 0 0.05" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <joint name="j1" type="revolute">
    <parent link="link_0"/>
    <child link="link_1"/>
    <origin xyz="0 0.15 0.15" rpy="0.0000 0.0000 1.5708"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <joint name="j2" type="revolute">
    <parent link="link_1"/>
    <child link="link_2"/>
    <origin xyz="0 0 0.3" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <joint name="j3" type="revolute">
    <parent link="link_2"/>
    <child link="link_3"/>
    <origin xyz="-0.15 0 0.15" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <joint name="j4" type="revolute">
    <parent link="link_3"/>
    <child link="link_4"/>
    <origin xyz="0 0.15 0.25" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

  <joint name="jtool" type="revolute">
    <parent link="link_4"/>
    <child link="tool"/>
    <origin xyz="0 0 0.15" rpy="0.0000 0.0000 0.0000"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="1.0"/>
  </joint>

</robot>
