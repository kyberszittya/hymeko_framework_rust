flowchart TD
    img[image] --> patch[patchify + initial Linear embed]
    patch --> sal[SalienceHead<br/>MLP → s_v per patch ∈ 0,1]
    sal --> topk[TopKSelector<br/>Gumbel-softmax in training<br/>hard top-K at inference]
    topk --> ksimnn[Anchor k-NN by feature similarity<br/>each anchor → ν=4 most similar]
    ksimnn --> sign[edge sign σ_u_v = sign of inner product − θ<br/>θ learned]
    sign --> hyper[StimulusGraphBuilder<br/>walks w2/w3, polygons c4/c5/c6, triangles c3<br/>over the K anchors only]
    hyper --> walk[WalkConvLayer<br/>Phase 2, unchanged]
    walk --> poly[PolygonConvLayer<br/>Phase 3-G, unchanged]
    poly --> tri[TriangleConvLayer<br/>Phase 4, when ready: balance gate]
    tri --> head[Detection head<br/>per-anchor cls + offset OR per-image cls]
    head --> output[mAP50 / accuracy]

    classDef sigma fill:#e9d5ff,stroke:#7e22ce
    classDef new fill:#fed7aa,stroke:#c2410c
    classDef reuse fill:#bbf7d0,stroke:#15803d
    class sal,topk,ksimnn,sign,hyper new
    class walk,poly,tri reuse

