%% Mermaid sequence diagram: per-edge sign lookup, before vs after.
%%
%% Render via:
%%   mmdc -i plan.mmd -o plan-seq.svg
%% (or paste into mermaid.live).

sequenceDiagram
    autonumber
    participant DFS as dfs_per_vertex
    participant CSR as (row_ptr, col_idx)
    participant HM as HashMap<br/>sign_lookup
    participant SC as signs_csr<br/>(new)

    Note over DFS,SC: BEFORE — 39% of CPU on hash_one

    DFS->>CSR: read col_idx[row_ptr[u]..row_ptr[u+1]]
    CSR-->>DFS: neighbour list
    loop for each candidate neighbour v
        DFS->>HM: get((min(u,v), max(u,v)))
        Note right of HM: SipHash · 2-word key<br/>~70 ns
        HM-->>DFS: sign i8
    end

    Note over DFS,SC: AFTER — sign lookup co-located with CSR

    DFS->>CSR: read col_idx[row_ptr[u]..row_ptr[u+1]]
    CSR-->>DFS: neighbour list + index range [s, e)
    loop for each candidate neighbour v at offset k in [s, e)
        DFS->>SC: signs_csr[k]
        Note right of SC: array index<br/>~5–10 ns
        SC-->>DFS: sign i8
    end
