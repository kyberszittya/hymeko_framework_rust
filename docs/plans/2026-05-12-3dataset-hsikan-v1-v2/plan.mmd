flowchart TD
    DATASETS["4 datasets<br/>Bitcoin Alpha (n=3,783)<br/>Bitcoin OTC (n=5,881)<br/>Slashdot (n=82,140)<br/>Epinions (n=131,828)"]

    CONFIGS["4 configs per dataset<br/>B: baseline (yesterday's recipe)<br/>V1: + vertex prefilter (compose:degree,triangle)<br/>V2: + FPN tiered (0.1:1024,1.0:256,5.0:64,20.0:16,100.0:0)<br/>V1+V2: both"]

    PHASE_A["<b>Phase A — 1-seed smoke</b><br/>All 16 dataset×config cells<br/>~9h total<br/>Gate: ΔAUC vs baseline ≤ 0.01"]

    PHASE_B["<b>Phase B — 5-seed Bitcoin</b><br/>Bitcoin Alpha + Bitcoin OTC<br/>~1h total<br/>Gate: paired Δ ≤ 0.005 vs baseline,<br/>SOTA preserved (0.9845 / 0.9801)"]

    PHASE_C["<b>Phase C — 5-seed Slashdot</b><br/>~3.7h<br/>Gate: V1+V2 wall ≤ 0.80× baseline<br/>AUC paired Δ ≤ ±0.002 of 0.9070"]

    PHASE_D["<b>Phase D — Epinions 2-config</b><br/>5-seed B vs best V1+V2 only<br/>~19h (requires explicit GPU-time go)<br/>Gate: AUC ≥ +0.010 OR wall ≤ 0.70×<br/>(else null — confirms ceiling claim)"]

    REPORT["reports/2026-05-13-3dataset-v1-v2.md<br/>Per-dataset paired AUC tables<br/>Cumulative wall savings<br/>Promotion verdicts"]

    HALT_A["Halt: drop failing<br/>(config, dataset) pairs"]
    HALT_B["Halt: V2 design fix<br/>required before Phase C"]
    HALT_C["Halt: V1 only<br/>for Phase D"]
    HALT_D["Document null<br/>(ceiling claim preserved)"]

    DATASETS --> PHASE_A
    CONFIGS --> PHASE_A
    PHASE_A -->|pass| PHASE_B
    PHASE_A -->|some fail| HALT_A
    HALT_A --> PHASE_B

    PHASE_B -->|pass| PHASE_C
    PHASE_B -->|V1+V2 drops > 0.01| HALT_B

    PHASE_C -->|pass| PHASE_D
    PHASE_C -->|V1+V2 drops > 0.005| HALT_C
    HALT_C --> PHASE_D

    PHASE_D --> REPORT
    PHASE_D -->|null| HALT_D
    HALT_D --> REPORT

