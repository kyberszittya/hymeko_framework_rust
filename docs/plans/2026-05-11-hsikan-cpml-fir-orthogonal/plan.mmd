flowchart LR
    subgraph axes["3 orthogonal architectural axes"]
        A["A: HSiKAN<br/>Catmull-Rom spline KAN<br/>(on/off)"]
        C["C: CPML topology<br/>L=1 flat vs L=3 tier-stratified<br/>(on/off)"]
        F["F: Clifford-FIR<br/>closed-form Clifford derivative<br/>(on/off)"]
    end

    subgraph cells["2³ = 8 cells of the factorial"]
        b000["baseline<br/>(A=0, C=0, F=0)<br/>MLP only"]
        b100["hsikan<br/>(1,0,0)"]
        b010["cpml<br/>(0,1,0)"]
        b001["fir<br/>(0,0,1)"]
        b110["cpml-hsikan<br/>(1,1,0)"]
        b101["hsikan-fir<br/>(1,0,1)<br/>α-routed"]
        b011["cpml-fir<br/>(0,1,1)"]
        b111["cpml-hsikan-fir<br/>(1,1,1)<br/>α-routed × CPML tiers"]
    end

    subgraph decomp["Factorial decomposition<br/>(linear regression)"]
        mu["μ: embedding floor"]
        a["α: HSiKAN main effect"]
        g["γ: CPML main effect"]
        f["φ: FIR main effect"]
        ag["αγ: HSiKAN×CPML interaction"]
        af["αφ: HSiKAN×FIR interaction"]
        gf["γφ: CPML×FIR interaction"]
        agf["αγφ: 3-way interaction"]
    end

    subgraph protocol["Measurement protocol"]
        seeds["5 seeds × 2 datasets"]
        paired["paired t-test vs<br/>embedding-only floor"]
        prereg["pre-registered<br/>hypotheses H1-H4"]
    end

    A -.-> b100
    A -.-> b110
    A -.-> b101
    A -.-> b111
    C -.-> b010
    C -.-> b110
    C -.-> b011
    C -.-> b111
    F -.-> b001
    F -.-> b101
    F -.-> b011
    F -.-> b111

    b000 --> seeds
    b100 --> seeds
    b010 --> seeds
    b001 --> seeds
    b110 --> seeds
    b101 --> seeds
    b011 --> seeds
    b111 --> seeds

    seeds --> paired
    paired --> decomp
    prereg --> paired

