flowchart TB
    subgraph Data["SoA data path (no tensors)"]
        Pool["CyclePool<br/>Vec&lt;u32&gt; cycles<br/>Vec&lt;i8&gt; signs"]
        Feats["Features Vec&lt;f32&gt;<br/>|V| × d row-major"]
        Cache["Cycle cache<br/>(graph hash × env-vars)"]
    end

    subgraph Map["Per-cycle Map (parallel-by-c)"]
        Fwd["f_θ(c, X) ∀ c<br/>FIR / spline / scatter"]
        Bwd["∂f_θ / ∂θ (c) ∀ c<br/>closed-form bwd"]
    end

    subgraph Reduce["Commutative reduce"]
        Smean["scatter-mean → H[v]<br/>per-vertex aggregation"]
        Gacc["atomic-add grad accum<br/>θ_g += Σ_c ∂f/∂θ(c)"]
    end

    subgraph Train["Training step"]
        Loss["BCE-with-logits<br/>loss + ∂loss/∂s"]
        Adam["Adam optimizer<br/>θ ← θ - α m̂/√v̂"]
    end

    subgraph Backend["Backend (same API)"]
        CPU["CPU Rayon"]
        WGPU["GPU wgpu portable"]
        CUDA["GPU cudarc fast"]
    end

    Pool --> Fwd
    Feats --> Fwd
    Pool --> Bwd
    Feats --> Bwd
    Fwd --> Smean
    Bwd --> Gacc

    Smean --> Loss
    Loss --> Gacc
    Gacc --> Adam
    Adam --> Fwd

    Fwd -.-> CPU
    Fwd -.-> WGPU
    Fwd -.-> CUDA
    Bwd -.-> CPU
    Bwd -.-> WGPU
    Bwd -.-> CUDA

    Cache --> Pool

    classDef soa fill:#cfe2ff,stroke:#0d6efd
    classDef mapnode fill:#fff3cd,stroke:#ffc107
    classDef rednode fill:#ffe5b4,stroke:#fd7e14
    classDef train fill:#d4edda,stroke:#198754
    classDef back fill:#e9ecef,stroke:#6c757d

    class Pool,Feats,Cache soa
    class Fwd,Bwd mapnode
    class Smean,Gacc rednode
    class Loss,Adam train
    class CPU,WGPU,CUDA back
