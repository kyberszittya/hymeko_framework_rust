  \draw[-{Stealth[length=3mm]}] (acfg)    -- (adisp);
  \draw[-{Stealth[length=3mm]}] (adisp)   -- (astrat);

  \draw[-{Stealth[length=3mm]},dashed,thick,red!60!black]
