\begin{tikzpicture}[node distance=8mm, font=\small,
  box/.style={draw,rounded corners,minimum height=8mm,inner sep=2mm,align=center},
  legacy/.style={box,fill=red!10},
  newshape/.style={box,fill=green!12}]

  % LEFT: BEFORE
  \node[legacy, minimum width=58mm] (before) {16 \texttt{\#[pyfunction]} wrappers\\(2251 LOC, 0 structs/traits)};
  \node[box, below=of before, minimum width=58mm] (bdetail) {\texttt{enumerate\_top\_k\_per\_vertex\_cycles\_signed\_filtered\_batched\_rs}\\\texttt{\_signed\_filtered\_bb\_batched\_rs}\\\texttt{\_signed\_filtered\_bb\_global\_batched\_rs}\\\texttt{\_signed\_tiered\_bb\_global\_batched\_rs}\\\dots};
