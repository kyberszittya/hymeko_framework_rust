  % RIGHT: AFTER
  \node[newshape, right=24mm of before, minimum width=58mm] (after) {2 family entry points\\\texttt{enumerate\_cycles\_rs}, \texttt{enumerate\_walks\_rs}\\($\sim$800 LOC)};
  \node[box, below=of after, minimum width=58mm] (acfg) {\texttt{EnumerationConfig}\\\{score, pruner, filter, abb,\\batched, tiered, fullness\_gate\}};
