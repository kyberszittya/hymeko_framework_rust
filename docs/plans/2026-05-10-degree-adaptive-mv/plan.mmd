%% Mermaid: per-vertex DFS with adaptive m_v.
%%
%% The only change from the current per-vertex top-K DFS is that
%% the heap-fill check uses m_v[v] (a per-vertex cap) instead of
%% a scalar m_per_vertex.  The state-update + ABB-on-threshold
%% machinery is identical.

sequenceDiagram
    autonumber
    participant DFS as dfs_per_vertex_adaptive
    participant CSR as (row_ptr, col_idx, signs_csr)
    participant MV as m_v[0..n_nodes]
    participant HEAPS as per_vertex[v].heap

    Note over DFS,HEAPS: closure (path = (v0, v1, v2, v3))

    DFS->>CSR: closing-edge sign lookup
    CSR-->>DFS: signs

    DFS->>DFS: pruner.emit_ok(path, signs)?

    loop for each v in path
        DFS->>MV: cap = m_v[v]
        MV-->>DFS: cap
        DFS->>HEAPS: peek heap[v]
        HEAPS-->>DFS: len, min_score
        alt len &lt; cap
            DFS->>HEAPS: push (cycle, score)
        else score &gt; min_score
            DFS->>HEAPS: pop + push (cycle, score)
        else
            DFS-->>DFS: drop (heap saturated)
        end
    end

    Note over DFS,HEAPS: extension step (potential future per-vertex ABB)

    DFS->>CSR: visited / BFS / extend_ok pre-checks
    CSR-->>DFS: pass

    Note over DFS,HEAPS: future: prune subtree if every cycle vertex<br/>has full heap with min &gt; UB(score)

    DFS->>DFS: recurse with updated path
