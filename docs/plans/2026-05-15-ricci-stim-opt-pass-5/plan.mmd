flowchart TD
    cur[Current: 28 ms / 35 FPS per image] --> ablation{Ablation result?}
    ablation -- "E >= 0.5 mAP50_proxy" --> proceed[Apply P5-P7]
    ablation -- "E in 0.235..0.5" --> partial[Apply P5-P7 + second seed]
    ablation -- "E < 0.235" --> halt[Architectural rethink; defer optimization]
    proceed --> p5[P5: profile + fix unaccounted 10 ms]
    p5 --> p6[P6: cache topology between SDRF passes]
    p6 --> p7[P7: vectorise polygon enumeration]
    p7 --> measured[~14 ms / 70 FPS measured]
    measured --> p8{Need more?}
    p8 -- yes --> p8_big[P8: GPU-level batching - architectural]
    p8 -- no --> done[Ship; queue real falsification battery]
    p8_big --> done

    classDef good fill:#bbf7d0,stroke:#15803d
    classDef warn fill:#fed7aa,stroke:#c2410c
    classDef stop fill:#fecaca,stroke:#b91c1c
    class done good
    class partial,p8_big warn
    class halt stop
