%% Generated by hymeko_query — Mermaid flowchart for {{config:robot_name}}
flowchart TD
    classDef link fill:#FFE4B5,stroke:#8B4513,stroke-width:2px,color:#000;
    classDef root fill:#DDD,stroke:#555,stroke-width:2px,color:#000;

{{#each links}}
{{#if field:mass}}
    {{name}}["<b>{{name}}</b><br/>{{field:mass}} kg"]:::link
{{/if}}
{{/each}}

{{#each fixed_joints}}
    {{bind:+:0}} -.->|"{{name}} (fixed)"| {{bind:-:0}}
{{/each}}
{{#each revolute_joints}}
    {{bind:+:0}} -->|"{{name}} (rev)"| {{bind:-:0}}
{{/each}}
{{#each continuous_joints}}
    {{bind:+:0}} -->|"{{name}} (cont)"| {{bind:-:0}}
{{/each}}
{{#each prismatic_joints}}
    {{bind:+:0}} -->|"{{name}} (prismatic)"| {{bind:-:0}}
{{/each}}
