<?xml version="1.0" encoding="UTF-8"?>
<sdf version="1.8">
  <world name="{{config:world_name}}">
    <physics name="default" type="ignored">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
    </physics>

    <plugin filename="gz-sim-physics-system" name="gz::sim::systems::Physics"/>
    <plugin filename="gz-sim-user-commands-system" name="gz::sim::systems::UserCommands"/>
    <plugin filename="gz-sim-scene-broadcaster-system" name="gz::sim::systems::SceneBroadcaster"/>

    <light type="directional" name="sun">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <plane>
              <normal>0 0 1</normal>
              <size>100 100</size>
            </plane>
          </geometry>
        </visual>
      </link>
    </model>

{{#each sim_plugins}}
    <plugin filename="{{field:filename}}" name="{{field:plugin}}">
{{#if field:parameters}}
      <parameters>{{field:parameters}}</parameters>
{{/if}}
    </plugin>
{{/each}}

    <model name="{{config:robot_name}}">
      <static>false</static>
{{#each links}}
      <link name="{{name}}">
{{#if field:mass}}
        <inertial>
          <mass>{{field:mass}}</mass>
          <inertia>
            <ixx>0.01</ixx><iyy>0.01</iyy><izz>0.01</izz>
            <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
          </inertia>
        </inertial>
{{/if}}
{{#if field:link_geometry}}
        <visual name="{{name}}_visual">
{{#if field:origin}}
          <pose relative_to="{{name}}">{{field:origin}} 0 0 0</pose>
{{/if}}
          <geometry>
{{#inherits link_geometry "box"}}
            <box><size>{{field:link_geometry.dimension}}</size></box>
{{/inherits}}
{{#inherits link_geometry "cylinder"}}
            <cylinder><radius>{{nth:link_geometry.dimension:0}}</radius><length>{{nth:link_geometry.dimension:1}}</length></cylinder>
{{/inherits}}
{{#inherits link_geometry "sphere"}}
            <sphere><radius>{{nth:link_geometry.dimension:0}}</radius></sphere>
{{/inherits}}
          </geometry>
        </visual>
        <collision name="{{name}}_collision">
          <geometry>
{{#inherits link_geometry "box"}}
            <box><size>{{field:link_geometry.dimension}}</size></box>
{{/inherits}}
{{#inherits link_geometry "cylinder"}}
            <cylinder><radius>{{nth:link_geometry.dimension:0}}</radius><length>{{nth:link_geometry.dimension:1}}</length></cylinder>
{{/inherits}}
{{#inherits link_geometry "sphere"}}
            <sphere><radius>{{nth:link_geometry.dimension:0}}</radius></sphere>
{{/inherits}}
          </geometry>
        </collision>
{{/if}}
      </link>
{{/each}}

{{#each fixed_joints}}
      <joint name="{{name}}" type="fixed">
        <parent>{{bind:+:0}}</parent>
        <child>{{bind:-:0}}</child>
      </joint>
{{/each}}

{{#each revolute_joints}}
      <joint name="{{name}}" type="revolute">
        <parent>{{bind:+:0}}</parent>
        <child>{{bind:-:0}}</child>
        <axis>
          <xyz>0 0 1</xyz>
        </axis>
      </joint>
{{/each}}

{{#each continuous_joints}}
      <joint name="{{name}}" type="revolute">
        <parent>{{bind:+:0}}</parent>
        <child>{{bind:-:0}}</child>
        <axis>
          <xyz>0 0 1</xyz>
          <limit>
            <lower>-1e16</lower>
            <upper>1e16</upper>
          </limit>
        </axis>
      </joint>
{{/each}}

{{#each control_plugins}}
{{#if field:filename}}
      <plugin filename="{{field:filename}}" name="{{field:plugin}}">
      </plugin>
{{/if}}
{{/each}}
    </model>
  </world>
</sdf>
